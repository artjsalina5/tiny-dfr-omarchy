#!/bin/bash
set -euo pipefail

SERVICE_NAME="omarchy-dynamic-function-row-daemon.service"

run_as_root() {
    if [ "${EUID:-$(id -u)}" -eq 0 ]; then
        "$@"
    elif command -v sudo >/dev/null 2>&1; then
        sudo "$@"
    else
        echo "Error: root privileges required to restart ${SERVICE_NAME}" >&2
        exit 1
    fi
}

run_as_root systemctl restart "$SERVICE_NAME"
exec omarchy-touchbar-status
